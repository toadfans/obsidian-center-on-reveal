{
	"name": "center-on-reveal",
	"version": "0.1.1",
	"description": "Centers and highlights the active file when it is revealed in the file explorer.",
	"main": "main.js",
	"type": "module",
	"packageManager": "bun@1.3.14",
	"scripts": {
		"dev": "bun esbuild.config.ts",
		"build:bundle": "bun esbuild.config.ts production",
		"build": "bun run build:bundle && bun scripts/sync-obsidian-local.ts",
		"install:vault": "bun run build:bundle && bun scripts/sync-obsidian-local.ts --install",
		"version": "bun scripts/version-bump.ts && git add manifest.json versions.json",
		"typecheck": "tsgo --noEmit --skipLibCheck",
		"lint": "eslint . && bun run typecheck",
		"test": "vitest run",
		"unused": "knip",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "bun run lint && bun run unused",
		"prepare": "husky"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@types/node": "^25.9.2",
		"@typescript/native-preview": "7.0.0-dev.20260607.1",
		"esbuild": "0.28.0",
		"eslint": "10.4.1",
		"eslint-plugin-obsidianmd": "0.3.0",
		"husky": "^9.1.7",
		"jiti": "2.7.0",
		"knip": "^6.16.1",
		"prettier": "^3.8.3",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"typescript-eslint": "8.60.1",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"obsidian": "1.13.0"
	},
	"overrides": {
		"typescript": "6.0.3"
	}
}
